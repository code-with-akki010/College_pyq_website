PORT=3000
MAX_FILE_SIZE_MB=50

# Supabase backend storage. Keep the service role key only on Render/server.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_BUCKET=papers
SUPABASE_TABLE=papers

# Optional local fallback when Supabase env vars are missing.
DB_FILE=campusbytes.sqlite
